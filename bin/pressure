#!/usr/bin/env python
from subprocess import PIPE, Popen
from sys import stdin, stderr
from os import environ


def main():
    environ["PYTHONUNBUFFERED"] = "1"
    infer = spawn("align xs.txt | sym2idx xs.txt | encode | infer | str")
    align = spawn("align ys.txt | sym2idx ys.txt")
    for line in stdin:
        infer.stdin.write(line)
        infer.stdin.flush()
        align.stdin.write(line)
        align.stdin.flush()
        values = list(map(float, infer.stdout.readline().split()))
        index = int(align.stdout.readline().split()[-1])
        negative = sum(values[0:index])
        positive = sum(values[index + 1 :])
        print(positive, negative)


def spawn(command):
    return Popen(
        ["bash", "-c", command], stdin=PIPE, stdout=PIPE, stderr=stderr, text=True
    )


if __name__ == "__main__":
    main()
