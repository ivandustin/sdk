#!/usr/bin/env python
from subprocess import PIPE, Popen
from sys import stdin, stderr
from numpy import array, loadtxt


def main():
    infer = spawn("align xs.txt | sym2idx xs.txt | encode | infer | str")
    symbols = loadtxt("ys.txt")
    for line in stdin:
        infer.stdin.write(line)
        output = infer.stdout.readline()
        items = output.split()
        values = array(items, dtype=float)
        value = float(line.split()[-1])
        low = values[symbols < value].sum()
        high = values[symbols > value].sum()
        print(low, high)


def spawn(command):
    return Popen(
        ["bash", "-c", command],
        stdin=PIPE,
        stdout=PIPE,
        stderr=stderr,
        text=True,
        bufsize=0,
    )


if __name__ == "__main__":
    main()
