#!/usr/bin/env bash
set -eo pipefail
if [[ "$MODEL" == "deepseek"* ]]
then
	domain=deepseek
	key=$DEEPSEEK
else
	domain=openai
	key=$OPENAI
fi

if [ "$OLLAMA" = 1 ]
then
	url=http://localhost:11434
else
	url=https://api.$domain.com
fi

if [ "$VERBOSE" = 1 ]
then
	verbose=-v
fi

if [ "$REQ" = 1 ]
then
	cat >&2
else
	curl -sL "$url/$1" \
		-H "Content-Type: application/json" \
		-H "Authorization: Bearer $key" \
		$verbose \
		-d @- | ugly
fi
