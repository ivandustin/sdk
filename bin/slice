#!/usr/bin/env python
from sys import argv, stdin
from numpy import loadtxt


def main():
    length = int(argv[1])
    filepath = argv[2]
    values = loadtxt(filepath, dtype=str, ndmin=1)
    for line in stdin:
        index = int(line)
        items = values[index : index + length]
        print(" ".join(items))


if __name__ == "__main__":
    main()
