#!/usr/bin/env python
from pathlib import Path
from sys import argv

BACKTICK = "`"
DELIMITER = BACKTICK * 3


def main():
    filepaths = map(Path, argv[1:])
    for filepath in filepaths:
        print(filepath)
        print(DELIMITER)
        print(filepath.read_text(encoding="utf-8"))
        print(DELIMITER)


if __name__ == "__main__":
    main()
