#!/usr/bin/env python
from sys import argv, stdin
from numpy import *


def main():
    expr = argv[1]
    for line in stdin:
        x = array(line.split()).astype(float)
        y = eval(expr)
        y = y.astype(str)
        y = y if isscalar(y) else " ".join(y.tolist())
        print(y)


if __name__ == "__main__":
    main()
